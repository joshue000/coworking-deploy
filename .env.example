# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=coworking_user
POSTGRES_PASSWORD=coworking_pass
POSTGRES_DB=coworking_db
POSTGRES_PORT=5432

# ─── API ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# REQUIRED: set a strong secret key before running
API_KEY=change-me-in-production

MQTT_CLIENT_ID=coworking-api

# IoT alert windows (seconds) — defaults shown, tune as needed
ALERT_CO2_OPEN_WINDOW_SEC=300
ALERT_CO2_RESOLVE_WINDOW_SEC=120
ALERT_OCCUPANCY_MAX_OPEN_WINDOW_SEC=120
ALERT_OCCUPANCY_MAX_RESOLVE_WINDOW_SEC=60
ALERT_OCCUPANCY_UNEXPECTED_OPEN_WINDOW_SEC=600
ALERT_OCCUPANCY_UNEXPECTED_RESOLVE_WINDOW_SEC=300
TELEMETRY_AGGREGATION_WINDOW_MIN=5

# ─── Frontend ──────────────────────────────────────────────────────────────────
# URL the BROWSER uses to reach the API (baked into bundle at build time)
VITE_API_BASE_URL=http://localhost:3000
FRONTEND_PORT=80
